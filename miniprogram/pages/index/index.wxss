/* miniprogram/pages/index/index.wxss */
.container {
  padding: 24rpx 24rpx 40rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

.title {
  font-weight: 600;
  color: var(--text-primary);
  font-size: 40rpx;
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.top_tip {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.function_title {
  font-weight: 600;
  color: var(--text-primary);
  font-size: 32rpx;
  text-align: left;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.power {
  background-color: var(--white);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.power_info {
  display: flex;
  padding: 28rpx 24rpx;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.power_info:active { background-color: var(--bg-section); }

.power_info_more,
.power_info_less,
.power_item_icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.power_info_more { transform: rotate(90deg); }
.power_info_less  { transform: rotate(270deg); }

.power_info_text { display: flex; flex-direction: column; flex: 1; min-width: 0; }

.power_info_text_title {
  margin-bottom: 8rpx;
  font-weight: 500;
  font-size: 30rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  line-height: 1.3;
}

.power_info_text_tag {
  margin-left: 12rpx;
  background-color: var(--danger-light);
  color: var(--danger-color);
  padding: 2rpx 12rpx;
  font-size: 22rpx;
  border-radius: 20rpx;
  line-height: 1.5;
  font-weight: 500;
}

.power_info_text_tip {
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.5;
}

.power_item {
  padding: 24rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: var(--bg-section);
}
.power_item:active { background-color: var(--divider); }

.power_item_title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.line {
  width: calc(100% - 48rpx);
  margin: 0 24rpx;
  height: 2rpx;
  background-color: var(--divider);
}

.environment {
  color: var(--text-placeholder);
  font-size: 24rpx;
  margin-top: 60rpx;
  text-align: center;
}

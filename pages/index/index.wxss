/* pages/index/index.wxss - 老板风格统一版 */
.index-container {
  min-height: 100vh;
  background-color: #F4F6FA;
  padding: 0 0 32rpx;
  box-sizing: border-box;
}

/* ========== 顶部用户信息卡 ========== */
.user-card {
  background: linear-gradient(135deg, #1A73E8 0%, #1557B0 100%);
  border-radius: 0 0 32rpx 32rpx;
  padding: 40rpx 32rpx 48rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(26, 115, 232, 0.15);
}
.user-card::after {
  content: '';
  position: absolute;
  top: -60rpx; right: -60rpx;
  width: 240rpx; height: 240rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}
.user-card::before {
  content: '';
  position: absolute;
  bottom: -80rpx; left: -40rpx;
  width: 200rpx; height: 200rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.user-info {
  flex: 1;
  min-width: 0;
  position: relative;
  z-index: 1;
}
.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.user-role-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.user-actions {
  display: flex;
  position: relative;
  z-index: 1;
}
.user-action-btn {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
}
.user-action-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}
.user-action-icon.logout-icon {
  color: #FFFFFF;
}
.user-action-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background-color: #FF4D4F;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-sizing: border-box;
}

/* ========== 通用 section ========== */
.section {
  margin: 24rpx 24rpx 0;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}
.section-header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 8rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  flex: 1;
}
.section-sub {
  font-size: 24rpx;
  color: #6B7280;
}
.section-badge {
  background-color: #FF4D4F;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  line-height: 1.5;
}

/* ========== 主模块卡片（横向 + 大卡） ========== */
.module-grid {
  padding: 8rpx 16rpx 16rpx;
}
.module-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-top: 8rpx;
  transition: background-color 0.2s;
}
.module-card:active {
  background-color: #F3F4F6;
}
.module-grid.single .module-card {
  background: linear-gradient(135deg, #F0F7FF 0%, #E3F0FF 100%);
}
.module-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
}
.module-icon-text {
  font-size: 38rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.module-info {
  flex: 1;
  min-width: 0;
}
.module-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 4rpx;
}
.module-desc {
  font-size: 24rpx;
  color: #6B7280;
}
.module-arrow {
  font-size: 36rpx;
  color: #9CA3AF;
  margin-left: 12rpx;
  line-height: 1;
}

/* ========== 列表卡片（卡列表式） ========== */
.card-list {
  padding: 0 8rpx 8rpx;
}
.card-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-bottom: 2rpx solid #F3F4F6;
  transition: background-color 0.2s;
}
.card-item:last-child {
  border-bottom: none;
}
.card-item:active {
  background-color: #F9FAFB;
}

.card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.06);
}

.card-content {
  flex: 1;
  min-width: 0;
}
.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-desc {
  font-size: 24rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
  margin-left: 12rpx;
  line-height: 1;
}
.card-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.card-dot.cutting_problem     { background-color: #FF4D4F; }
.card-dot.workshop_problem    { background-color: #FAAD14; }
.card-dot.processing_submit   { background-color: #1A73E8; }
.card-dot.product_problem     { background-color: #7B1FA2; }

/* ========== 底部安全区 ========== */
.safe-bottom {
  height: 32rpx;
}

/* ========== 模块图标背景渐变 ========== */
.raw-icon      { background: linear-gradient(135deg, #1A73E8 0%, #1557B0 100%); }
.cutting-icon  { background: linear-gradient(135deg, #FB8C00 0%, #E65100 100%); }
.workshop-icon { background: linear-gradient(135deg, #34A853 0%, #1B5E20 100%); }
.finished-icon { background: linear-gradient(135deg, #7B1FA2 0%, #4A148C 100%); }
/* 成品 4 个子模块：同紫色系 + 深浅区分 */
.finished-inbound-icon  { background: linear-gradient(135deg, #BA68C8 0%, #8E24AA 100%); }
.finished-stock-icon    { background: linear-gradient(135deg, #9C27B0 0%, #6A1B9A 100%); }
.finished-outbound-icon { background: linear-gradient(135deg, #7B1FA2 0%, #4A148C 100%); }
.finished-record-icon   { background: linear-gradient(135deg, #AB47BC 0%, #6A1B9A 100%); }
.boss-icon     { background: linear-gradient(135deg, #455A64 0%, #263238 100%); }

/* 裁剪加工/裁剪记录：与裁剪同色系但稍有区分（深/浅橙色） */
.cutting-add-icon { background: linear-gradient(135deg, #FFA726 0%, #FB8C00 100%); }
.cutting-rec-icon { background: linear-gradient(135deg, #FFB74D 0%, #F57C00 100%); }
/* 车间待加工/车间生产/车间记录：与车间同色系但稍有区分 */
.workshop-pending-icon { background: linear-gradient(135deg, #FFC107 0%, #F57F17 100%); }
.workshop-proc-icon { background: linear-gradient(135deg, #66BB6A 0%, #2E7D32 100%); }
.workshop-rec-icon  { background: linear-gradient(135deg, #81C784 0%, #388E3C 100%); }


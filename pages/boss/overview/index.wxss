/* pages/boss/overview/index.wxss */
.overview-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.welcome-bar {
  background: linear-gradient(135deg, #1A73E8 0%, #1557B0 100%);
  border-radius: 20rpx;
  padding: 32rpx 32rpx 36rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--text-inverse);
  position: relative;
  overflow: hidden;
}
.welcome-bar::after {
  content: '';
  position: absolute;
  top: -40rpx; right: -40rpx;
  width: 220rpx; height: 220rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}
.welcome-left { position: relative; z-index: 1; }
.welcome-right {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.welcome-logout {
  font-size: 24rpx;
  color: var(--text-inverse);
  background: rgba(255, 255, 255, 0.16);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  line-height: 1.4;
}
.welcome-logout-hover { background: rgba(255, 255, 255, 0.3); }
.welcome-title {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--text-inverse);
  line-height: 1.3;
}
.welcome-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-top: 8rpx;
}
.welcome-role {
  font-size: 24rpx;
  color: var(--text-inverse);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  position: relative;
  z-index: 1;
}

.section { margin-bottom: 24rpx; }
.section:last-child { margin-bottom: 0; }

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 26rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.stat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-card {
  flex: 1 1 calc(50% - 8rpx);
  min-width: calc(50% - 8rpx);
  background: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-md);
  box-sizing: border-box;
  position: relative;
}
.stat-card.warning { border-left: 6rpx solid var(--warning-color); }
.stat-card.primary { border-left: 6rpx solid var(--primary-color); }
.stat-card.success { border-left: 6rpx solid var(--success-color); }

.stat-value {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.2;
  font-variant-numeric: tabular-nums;
}
.text-primary { color: var(--primary-color); }
.text-warning { color: var(--warning-color); }
.text-success { color: var(--success-color); }

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  line-height: 1.4;
}

.big-stat-card {
  background: linear-gradient(135deg, #FB8C00 0%, #F26522 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-inverse);
  box-shadow: var(--shadow-md);
}
.big-value {
  font-size: 80rpx;
  font-weight: 600;
  color: var(--text-inverse);
  line-height: 1;
  font-variant-numeric: tabular-nums;
}
.big-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.quick-links {
  display: flex;
  flex-wrap: wrap;
  background: var(--white);
  border-radius: 16rpx;
  padding: 16rpx 8rpx;
  box-shadow: var(--shadow-md);
}
.link-item {
  /* 老板工作台放 5 个快捷入口，5 × 20% = 100%，整齐一行 */
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
}
.link-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: var(--primary-light);
  color: var(--primary-color);
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.link-icon-stats {
  background: var(--gold-light);
  color: var(--gold-color);
}
.link-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* pages/boss/settings/data-export/index.wxss */
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: 24rpx;
  box-sizing: border-box;
}

.notice-box {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.notice-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.menu-list {
  background-color: var(--white);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--divider);
}
.menu-item:last-child { border-bottom: none; }

.menu-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.export-btn {
  background-color: var(--primary-color);
  color: var(--text-inverse);
  padding: 0 28rpx;
  height: 60rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.export-btn::after { border: none; }

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.empty-tip {
  font-size: 26rpx;
  color: var(--success-color);
}

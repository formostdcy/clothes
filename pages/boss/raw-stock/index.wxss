/* pages/boss/raw-stock/index.wxss
 * 老板视角-原材料库存明细样式
 * 复用原材料管理员库存明细风格（不带新增按钮）
 */

.container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 0 0 40rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ========== 顶部信息 ========== */
.header {
  background: linear-gradient(135deg, #1A73E8 0%, #1668D8 100%);
  padding: 32rpx 32rpx 28rpx;
  box-sizing: border-box;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(26, 115, 232, 0.18);
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 6rpx;
}
.header-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 20rpx;
  line-height: 1.4;
}
.header-stats {
  display: flex;
  gap: 32rpx;
  background-color: rgba(255, 255, 255, 0.14);
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
  min-width: 0;
}
.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.3;
}
.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
}

/* ========== 列表 ========== */
.list {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx 24rpx 0;
}

.stock-card {
  width: 100%;
  max-width: 100%;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stock-name {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  width: 100%;
  box-sizing: border-box;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #EEF0F3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.cat-one {
  font-size: 26rpx;
  color: #999999;
  font-weight: 500;
  flex: 0 0 auto;
}
.cat-sep {
  font-size: 26rpx;
  color: #999999;
  flex: 0 0 auto;
}
.cat-two {
  font-size: 30rpx;
  color: #333333;
  font-weight: 700;
  flex: 1 1 0;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.stock-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
}
.stock-qty {
  flex: 0 0 auto;
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.2;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
}
.stock-qty.warning {
  color: #EA4335;
}
.stock-threshold {
  flex: 1 1 0;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}

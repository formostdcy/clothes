/* pages/boss/employee/add/index.wxss */
.form-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: 20rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.form-card {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
  box-shadow: var(--shadow-md);
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--divider);
}
.form-card > .form-item:last-child { border-bottom: none; padding-bottom: 16rpx; }

.form-label {
  font-size: 28rpx;
  color: var(--text-regular);
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}
.form-label.required::before {
  content: '*';
  color: var(--danger-color);
  margin-right: 6rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: var(--bg-section);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  transition: border-color 0.2s, background-color 0.2s;
}
.form-input:focus {
  border-color: var(--primary-color);
  background-color: var(--white);
}

.picker-display {
  height: 80rpx;
  background-color: var(--bg-section);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  box-sizing: border-box;
  color: var(--text-primary);
}
.picker-display.placeholder { color: var(--text-placeholder); }

.submit-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 16rpx 24rpx;
  background-color: var(--white);
  border-top: 2rpx solid var(--divider);
  box-shadow: 0 -2rpx 12rpx rgba(15, 23, 42, 0.06);
  z-index: 100;
  box-sizing: border-box;
}
.submit-bar.safe-bottom {
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.btn-block {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background-color: var(--primary-color);
  color: var(--text-inverse);
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
}
.btn-block::after { border: none; }
.btn-block:active { opacity: 0.85; }

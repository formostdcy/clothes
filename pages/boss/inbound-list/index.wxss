/* pages/boss/inbound-list/index.wxss
 * 老板视角-入库记录列表
 * - 顶部：蓝色渐变 + 标题 + 汇总
 * - 日期筛选：5 个胶囊 tab（今日/昨日/本周/本月/自定义）
 * - 自定义日期范围：横排两个日期选择器
 * - 卡片：单号 + 状态徽章 + 供应商 + 物料明细
 */

.container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 0 0 40rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ============ 顶部 ============ */
.header {
  background: linear-gradient(135deg, #1A73E8 0%, #1668D8 100%);
  padding: 32rpx 32rpx 28rpx;
  box-sizing: border-box;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(26, 115, 232, 0.18);
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 6rpx;
}
.header-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 20rpx;
  line-height: 1.4;
}
.header-stats {
  display: flex;
  align-items: stretch;
  gap: 24rpx;
  background-color: rgba(255, 255, 255, 0.14);
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
}
.stat-item {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
}
.stat-divider {
  flex: 0 0 2rpx;
  background-color: rgba(255, 255, 255, 0.28);
  align-self: stretch;
}
.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.3;
}
.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
}

/* ============ 日期筛选（胶囊 tab） ============ */
.date-tabs {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 24rpx 0;
  box-sizing: border-box;
  background-color: #f5f7fa;
}
.date-tab {
  flex: 1 1 0;
  min-width: 0;
  height: 64rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #666666;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
  transition: all 0.15s;
}
.date-tab.active {
  background: linear-gradient(135deg, #1A73E8 0%, #1668D8 100%);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(26, 115, 232, 0.32);
}

/* ============ 自定义日期范围 ============ */
.custom-range {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 16rpx 24rpx 0;
  box-sizing: border-box;
  background-color: #f5f7fa;
}
.custom-item {
  flex: 1 1 0;
  min-width: 0;
  height: 64rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
  gap: 8rpx;
  overflow: hidden;
}
.custom-label {
  font-size: 24rpx;
  color: #999999;
  line-height: 1;
  flex: 0 0 auto;
}
.custom-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 600;
  line-height: 1;
  flex: 1 1 0;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.custom-sep {
  font-size: 24rpx;
  color: #999999;
  line-height: 1;
  flex: 0 0 auto;
}

/* ============ 列表 ============ */
.list {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx 24rpx 0;
}

.order-card {
  width: 100%;
  max-width: 100%;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
  flex-wrap: wrap;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #EEF0F3;
}
.order-no {
  flex: 1 1 0;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #333333;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.badge {
  flex: 0 0 auto;
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 24rpx;
  line-height: 1.5;
  background-color: #f0f1f3;
  color: #666666;
  white-space: nowrap;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}
.badge.badge-success { background-color: #e6f9ed; color: #07c160; }
.badge.badge-warning { background-color: #fff7e6; color: #ff9500; }
.badge.badge-danger { background-color: #fde7e7; color: #EA4335; }
.badge.badge-grey { background-color: #f0f1f3; color: #666666; }

.card-meta {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  width: 100%;
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.card-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  font-size: 24rpx;
  color: #333333;
  line-height: 1.5;
  width: 100%;
  box-sizing: border-box;
}
.m-cat-two {
  color: #333333;
  font-weight: 500;
}
.m-qty {
  color: #1A73E8;
  font-weight: 500;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
}

.footer-tip {
  text-align: center;
  padding: 24rpx 0 0;
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
}

/* ============ 空数据 ============ */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0 60rpx;
  gap: 16rpx;
}
.empty-icon {
  font-size: 80rpx;
  line-height: 1;
  opacity: 0.5;
}
.empty-text {
  font-size: 28rpx;
  color: #999999;
  line-height: 1.4;
}

/* pages/boss/orders/detail/index.wxss */
.container {
  padding: 24rpx;
}

.section {
  background-color: var(--white);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--divider);
  color: var(--text-primary);
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 24rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 24rpx;
  border-bottom: 2rpx solid var(--divider);
  font-size: 28rpx;
  line-height: 1.5;
}
.info-row:last-child { border-bottom: none; }
.info-label { color: var(--text-secondary); flex-shrink: 0; }
.info-value { color: var(--text-primary); text-align: right; font-weight: 500; }
.status { color: var(--primary-color); }

.item-list { padding: 0; }
.item {
  padding: 24rpx;
  border-bottom: 2rpx solid var(--divider);
}
.item:last-child { border-bottom: none; }
.item-name {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  font-weight: 500;
}
.item-spec, .item-count {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

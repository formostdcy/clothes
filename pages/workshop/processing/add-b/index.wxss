/* pages/workshop/processing/add-b/index.wxss */
.form-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: 20rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 16rpx;
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-md);
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--text-regular);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input,
.picker-value {
  width: 100%;
  height: 80rpx;
  background-color: var(--bg-section);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  line-height: 80rpx;
  transition: border-color 0.2s, background-color 0.2s;
}
.input:focus,
.picker-value:focus { border-color: var(--primary-color); background-color: var(--white); }

.info-box {
  background-color: var(--bg-section);
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-regular);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  line-height: 1.5;
}

.btn-primary {
  background-color: var(--primary-color);
  color: var(--text-inverse);
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-top: 24rpx;
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.85; }

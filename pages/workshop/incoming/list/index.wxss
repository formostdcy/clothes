/* pages/workshop/incoming/list/index.wxss
 * ============================================================
 *  与 pages/workshop/pending/list 完全一致
 *  - 单号顶行（全宽）
 *  - 信息区独占整张卡片宽度（彻底解决挤压问题）
 *  - 底部双按钮横排 50:50 平分整宽（不可能溢出）
 *  视觉：浅灰底 + 白色卡片 + 16rpx 圆角 + 柔和阴影 + 24rpx 32rpx padding
 *  按钮：胶囊形（border-radius: 999rpx），内文字+图标水平垂直居中
 * ============================================================
 */

/* ================== 根容器（page 风格） ================== */
.container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx 24rpx 32rpx;
  box-sizing: border-box;
  overflow-x: hidden;             /* 关键：禁止横向滚动 */
}

/* ================== Tabs ================== */
.tabs {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
  width: 100%;
}
.tab {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999999;
  position: relative;
  transition: color 0.2s, background-color 0.2s;
}
.tab.active {
  color: #1A73E8;
  font-weight: 600;
  background-color: #F4F8FE;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 56rpx;
  height: 4rpx;
  background-color: #1A73E8;
  border-radius: 2rpx;
}

/* ================== List ================== */
.list {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ================== 卡片 ==================
   关键：信息区 + 按钮上下分布，不再有左右争用空间 */
.list-item {
  width: 100%;
  max-width: 100%;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 20rpx;                    /* 单号 / 信息 / 按钮 三段之间 20rpx */
}

/* ================== 单号顶行 ================== */
.item-no {
  font-size: 30rpx;
  color: #333333;
  font-weight: 700;
  line-height: 1.4;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  white-space: nowrap;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #EEF0F3;
}
.item-no-label {
  flex: 0 0 auto;
  color: #999999;
  font-weight: 500;
  font-size: 26rpx;
}
.item-no-value {
  flex: 1 1 0;
  min-width: 0;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  letter-spacing: -1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
  max-width: 100%;
}

/* ================== 信息区（核心：独占整宽） ==================
   关键：独立占一整行，宽度 100%，不会撑爆，永远不挤压 */
.item-info {
  width: 100%;
  max-width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.item-creator,
.item-material,
.item-quantity,
.item-time {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.55;
  display: block;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ================== 照片缩略图 ================== */
.item-photos {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}
.photo-label {
  font-size: 22rpx;
  color: #999999;
}
.photo-scroll {
  width: 100%;
  max-width: 100%;
  white-space: nowrap;
  box-sizing: border-box;
}
.photo-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}
.photo-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  background-color: #f5f5f5;
  border: 2rpx solid #EEF0F3;
  flex-shrink: 0;
  display: block;
}

/* ================== 备注 ================== */
.item-remark {
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  background-color: #fffbe6;
  border-left: 6rpx solid #ffc53d;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #614700;
  word-break: break-all;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}
.remark-label {
  font-weight: 600;
  color: #d48806;
  margin-right: 4rpx;
}
.remark-text {
  color: #614700;
}

/* ================== 底部操作区：双按钮横排 50:50 ==================
   关键：从"右侧固定列"改为"底部横排 50:50 平分整宽"
   信息区不再与按钮争用空间，按钮也不可能溢出 */
.item-actions {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: stretch;
  gap: 20rpx;
  width: 100%;
  max-width: 100%;
  margin-top: 8rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* ================== 按钮（胶囊形） ==================
   关键：flex: 1（等分剩余空间），不再固定宽度
   配合外层 justify-content: space-between
   两个按钮平分整卡宽度，文字永远不会被截断 */
.action-btn {
  flex: 1 1 0;
  min-width: 0;
  flex-shrink: 1;
  flex-grow: 1;
  height: 72rpx;
  min-height: 72rpx;
  line-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 999rpx;          /* 胶囊形 */
  padding: 0 12rpx;
  margin: 0;
  box-sizing: border-box;
  overflow: hidden;
  letter-spacing: 0;
  text-align: center;
  border: 2rpx solid transparent;
  transition: opacity 0.2s, transform 0.1s;
}
.action-btn::after {
  border: none;
  content: '';
  width: auto;
  height: auto;
}
.action-btn:active {
  opacity: 0.75;
  transform: scale(0.98);
}

.action-btn.confirm {
  background: linear-gradient(135deg, #07c160 0%, #06a050 100%);
  color: #ffffff;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.25);
}
.action-btn.problem {
  background-color: #fff5f5;
  color: #fa5151;
  border: 2rpx solid #fadbd9;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(250, 81, 81, 0.08);
}
.action-btn.problem:active {
  background-color: #ffe9e9;
}

.action-icon {
  font-size: 26rpx;
  font-weight: 700;
  margin-right: 8rpx;
  line-height: 1;
  display: inline-block;
  flex-shrink: 0;
  align-self: center;
}
.action-text {
  font-size: 28rpx;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
  display: inline-block;
  align-self: center;
}

/* ================== 已确认状态 ================== */
.item-status {
  width: 100%;
  text-align: center;
  box-sizing: border-box;
}
.status-text {
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}
.status-text.success { color: #34A853; }

/* ================== Empty ================== */
.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* pages/raw/outbound/add/index.wxss */
.form-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: 20rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.form-section {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-md);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--divider);
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 24rpx;
  background: var(--primary-color);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.material-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.material-item {
  background-color: var(--bg-section);
  border-radius: 12rpx;
  padding: 20rpx;
  position: relative;
}

.material-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 12rpx;
}
.material-row:last-child { margin-bottom: 0; }

.picker-inline {
  flex: 1;
  height: 72rpx;
  background-color: var(--white);
  border: 2rpx solid transparent;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  box-sizing: border-box;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: border-color 0.2s;
}
.picker-inline:focus-within { border-color: var(--primary-color); }

.input-inline {
  flex: 1;
  height: 72rpx;
  background-color: var(--white);
  border: 2rpx solid transparent;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: border-color 0.2s;
}
.input-inline:focus { border-color: var(--primary-color); }

.unit-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  min-width: 60rpx;
  flex-shrink: 0;
}

.remove-btn {
  font-size: 26rpx;
  color: var(--danger-color);
  min-width: 80rpx;
  text-align: right;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  background-color: var(--danger-light);
  flex-shrink: 0;
}

.btn-add-material {
  width: 100%;
  height: 72rpx;
  background-color: var(--primary-light);
  color: var(--primary-color);
  border: 2rpx dashed var(--primary-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.btn-add-material::after { border: none; }

.form-item { margin-bottom: 8rpx; padding: 8rpx 0; }

.form-label {
  font-size: 28rpx;
  color: var(--text-regular);
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}
.form-label.required::before {
  content: '*';
  color: var(--danger-color);
  margin-right: 6rpx;
  font-weight: 600;
}

.picker-display {
  height: 80rpx;
  background-color: var(--bg-section);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  box-sizing: border-box;
  color: var(--text-primary);
  transition: border-color 0.2s, background-color 0.2s;
}
.picker-display.placeholder { color: var(--text-placeholder); }
.picker-display:focus-within { border-color: var(--primary-color); background-color: var(--white); }

.radio-group {
  display: flex;
  gap: 16rpx;
}

.radio-item {
  flex: 1;
  height: 80rpx;
  background-color: var(--bg-section);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  transition: all 0.2s;
}
.radio-item.active {
  border-color: var(--primary-color);
  background-color: var(--primary-light);
  color: var(--primary-color);
  font-weight: 600;
}

.submit-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 16rpx 24rpx;
  background-color: var(--white);
  border-top: 2rpx solid var(--divider);
  box-shadow: 0 -2rpx 12rpx rgba(15, 23, 42, 0.06);
  z-index: 100;
  box-sizing: border-box;
}
.submit-bar.safe-bottom { padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); }

.btn-block {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background-color: var(--primary-color);
  color: var(--text-inverse);
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
}
.btn-block::after { border: none; }
.btn-block:active { opacity: 0.85; }

.stock-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin: 8rpx 0 12rpx;
  padding: 8rpx 16rpx;
  background: var(--bg-section);
  border-radius: 8rpx;
  display: inline-block;
}
.stock-hint .stock-zero {
  color: var(--danger-color);
  font-weight: 500;
}
.stock-hint .stock-low {
  color: var(--warning-color);
  font-weight: 500;
}

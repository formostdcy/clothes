<!-- pages/raw/settings/supplier/index.wxml -->
<view class="page page--tight page--with-submit">
  <!-- 搜索栏 -->
  <view class="filter-bar">
    <view class="search-pill">
      <view class="search-pill-icon">🔍</view>
      <input class="search-pill-input" placeholder="搜索供应商名称" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" />
    </view>
  </view>

  <!-- 列表 -->
  <view class="list">
    <view class="list-item list-item--clickable" wx:for="{{list}}" wx:key="_id" data-item="{{item}}" bindtap="onEdit">
      <view class="list-item-info">
        <view class="list-item-no">{{item.name}}</view>
        <view class="list-item-meta">联系人：{{item.contact_name || '-'}}{{item.contact_phone ? ' · ' + item.contact_phone : ''}}</view>
      </view>
      <view class="list-item-right">
        <view class="action-btn action-btn-danger" catchtap="onDelete" data-id="{{item._id}}" data-name="{{item.name}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{list.length === 0 && !loading}}">
    <view class="empty-state-icon">📭</view>
    <view class="empty-state-text">暂无供应商<br/>点右下角"+"添加</view>
  </view>

  <!-- 底部新增按钮 -->
  <view class="submit-bar safe-bottom">
    <button class="btn btn-primary btn-block" bindtap="onAdd">+ 新增供应商</button>
  </view>
</view>

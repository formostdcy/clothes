/* pages/cutting/record/index.wxss
 * 卡片结构对齐"车间管理员-待加工确认"风格：
 *  - 浅灰底 + 白色卡片 + 16rpx 圆角 + 柔和阴影
 *  - 单号顶行（标签 + 单号 + 状态徽章在同一行）
 *  - 信息区独占整宽，"标签:值"水平布局
 *  - 尺码明细用 chip 标签展示
 *  - 卡片整张可点击（点击事件已在 wxml 绑定 onDetail）
 */

.container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx 24rpx 32rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ========== List ========== */
.list {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ========== 卡片 ========== */
.list-item {
  width: 100%;
  max-width: 100%;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ========== 单号行 ========== */
.item-no {
  font-size: 30rpx;
  color: #333333;
  font-weight: 700;
  line-height: 1.4;
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #EEF0F3;
}

.item-label {
  flex: 0 0 auto;
  color: #999999;
  font-weight: 500;
  font-size: 26rpx;
}

.item-no-value {
  flex: 1 1 0;
  min-width: 0;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  letter-spacing: -1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
  max-width: 100%;
}

/* 状态徽章：单号行右侧 */
.item-status {
  flex: 0 0 auto;
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 24rpx;
  line-height: 1.5;
  background-color: #f0f1f3;
  color: #666666;
  white-space: nowrap;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}
.status-pending,
.status-pending-confirm { background-color: #fff7e6; color: #ff9500; }
.status-completed,
.status-done { background-color: #e6f9ed; color: #07c160; }
.status-all { background-color: #f0f1f3; color: #666666; }
.status-confirmed,
.status-cut { background-color: #E8F0FE; color: #1A73E8; }
.status-returned,
.status-issue { background-color: #fde7e7; color: #EA4335; }

/* ========== 信息区 ========== */
.item-info {
  width: 100%;
  max-width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.info-row {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.55;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.info-row .item-label {
  font-size: 24rpx;
}
.info-value {
  flex: 1 1 0;
  min-width: 0;
  color: #333333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 尺码明细行 ========== */
.item-sizes {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  width: 100%;
  max-width: 100%;
  font-size: 24rpx;
  line-height: 1.5;
  box-sizing: border-box;
  overflow: hidden;
}
.item-sizes .item-label {
  color: #999999;
  font-weight: 500;
  font-size: 24rpx;
  padding-top: 6rpx;
  flex: 0 0 auto;
}
.sizes-list {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.size-chip {
  display: inline-block;
  padding: 4rpx 14rpx;
  background-color: #E8F0FE;
  color: #1A73E8;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
  font-family: "SF Mono", "Monaco", "Consolas", monospace;
}

/* ========== 空数据 ========== */
.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}

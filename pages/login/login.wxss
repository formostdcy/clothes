/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1A73E8 0%, #1557B0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 60rpx;
  box-sizing: border-box;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: 600;
  color: var(--text-inverse);
  letter-spacing: 4rpx;
  line-height: 1.3;
}

.sub-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
  letter-spacing: 8rpx;
}

.login-form {
  width: 100%;
  background-color: var(--white);
  border-radius: 24rpx;
  padding: 56rpx 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.18);
}

.login-form .form-item {
  margin-bottom: 32rpx;
}
.login-form .form-item:last-of-type { margin-bottom: 16rpx; }

.login-form .form-input {
  width: 100%;
  height: 96rpx;
  background-color: var(--bg-section);
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.2s;
}
.login-form .form-input:focus {
  border-color: var(--primary-color);
  background-color: var(--white);
}

.placeholder {
  color: var(--text-placeholder);
}

.login-form .btn-block {
  margin-top: 16rpx;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  background-color: var(--primary-color);
  color: var(--text-inverse);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.login-form .btn-block::after { border: none; }
.login-form .btn-block:active { opacity: 0.85; }

/* 已登录提示卡片 */
.cached-tip {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}
.cached-tip-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}
.cached-tip-btns {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.btn.btn-secondary {
  height: 72rpx;
  line-height: 72rpx;
  background: #f0f0f0;
  color: #333;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
}
.btn.btn-secondary::after { border: none; }
.btn.btn-link {
  height: 60rpx;
  line-height: 60rpx;
  background: transparent;
  color: #1A73E8;
  font-size: 26rpx;
  border: none;
}
.btn.btn-link::after { border: none; }

/* pages/finished/stock/index.wxss
 * 全新排版
 * - 顶部：渐变背景 + 标题 + 汇总 + 导出按钮
 * - 筛选：横向滚动 picker
 * - 卡片：尺寸+库存 顶行 + 信息区 标签:值
 * - 浅灰底 + 白色卡片 + 16rpx 圆角 + 柔和阴影
 */

.container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 0 0 40rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ============ 顶部 ============ */
.header {
  background: linear-gradient(135deg, #1A73E8 0%, #1668D8 100%);
  padding: 28rpx 32rpx 24rpx;
  box-sizing: border-box;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(26, 115, 232, 0.18);
}
.header-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.header-left {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}
.header-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.3;
}
.header-btn {
  flex: 0 0 auto;
  font-size: 24rpx;
  color: #1A73E8;
  background-color: #ffffff;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  line-height: 1.4;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.header-stats {
  display: flex;
  align-items: stretch;
  gap: 24rpx;
  background-color: rgba(255, 255, 255, 0.14);
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
}
.stat-item {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
}
.stat-divider {
  flex: 0 0 2rpx;
  background-color: rgba(255, 255, 255, 0.28);
  align-self: stretch;
}
.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.3;
}
.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
}

/* ============ 筛选区（横向滚动） ============ */
.filter-scroll {
  width: 100%;
  max-width: 100%;
  white-space: nowrap;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background-color: #f5f7fa;
}
.filter-item {
  display: inline-block;
  vertical-align: top;
  margin-right: 12rpx;
  background-color: #ffffff;
  border-radius: 999rpx;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
  overflow: hidden;
  height: 64rpx;
  line-height: 64rpx;
}
.filter-item:last-child {
  margin-right: 0;
}
.filter-item.active {
  background-color: #E8F0FE;
  box-shadow: 0 2rpx 8rpx rgba(26, 115, 232, 0.18);
}
.filter-inner {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  box-sizing: border-box;
  white-space: nowrap;
}
.filter-prefix {
  font-size: 24rpx;
  color: #999999;
  line-height: 1;
  flex: 0 0 auto;
}
.filter-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 600;
  line-height: 1;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 0 0 auto;
}
.filter-item.active .filter-value {
  color: #1A73E8;
}
.filter-item.active .filter-prefix {
  color: #1A73E8;
}

/* ============ 列表 ============ */
.list {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx;
}

/* ============ 卡片 ============ */
.list-item {
  width: 100%;
  max-width: 100%;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
  padding: 24rpx 28rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 卡片顶行：尺寸+库存 */
.item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #EEF0F3;
}
.item-size {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.size-dot {
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, #1A73E8 0%, #1668D8 100%);
  border-radius: 50%;
  flex: 0 0 auto;
}
.size-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.2;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
}
.item-stock {
  flex: 0 0 auto;
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.stock-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A73E8;
  line-height: 1;
  font-family: "SF Mono", "Monaco", "Consolas", "Courier New", monospace;
}
.stock-unit {
  font-size: 22rpx;
  color: #999999;
  line-height: 1;
}

/* 信息区：标签:值 水平布局 */
.item-info {
  width: 100%;
  max-width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-sizing: border-box;
  overflow: hidden;
}
.info-row {
  font-size: 24rpx;
  line-height: 1.55;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.info-label {
  flex: 0 0 auto;
  color: #999999;
  font-weight: 500;
  font-size: 24rpx;
}
.info-value {
  flex: 1 1 0;
  min-width: 0;
  color: #333333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============ 空数据 ============ */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0 60rpx;
  gap: 16rpx;
}
.empty-icon {
  font-size: 80rpx;
  line-height: 1;
  opacity: 0.5;
}
.empty-text {
  font-size: 28rpx;
  color: #999999;
  line-height: 1.4;
}

/* ============ 底部提示 ============ */
.footer-tip {
  text-align: center;
  padding: 24rpx 0 0;
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
}

/* pages/finished/outbound/record/index.wxss */
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: 20rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.filter-bar {
  display: flex;
  gap: 8rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}
.filter-item {
  flex: 1;
  min-width: 140rpx;
  height: 72rpx;
  background-color: var(--white);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 12rpx;
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
}
.filter-item--reset {
  color: var(--primary-color);
  background-color: rgba(26, 115, 232, 0.08);
  border: 2rpx solid var(--primary-color);
  flex: 0 0 auto;
  padding: 0 20rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.list-item {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-md);
  box-sizing: border-box;
  transition: opacity 0.15s;
}
.list-item:active { opacity: 0.75; }

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-no {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.item-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  line-height: 1.5;
  background-color: var(--bg-section);
  color: var(--text-secondary);
}
.status-out,
.status-done { background-color: var(--success-light); color: var(--success-color); }
.status-pending-out,
.status-pending-confirm { background-color: var(--warning-light); color: var(--warning-color); }
.status-canceled,
.status-returned,
.status-issue { background-color: var(--bg-section); color: var(--text-secondary); }

.item-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.info-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}

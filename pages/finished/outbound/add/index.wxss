/* pages/finished/outbound/add/index.wxss */

/* ====== 顶部返回条 ====== */
.back-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.back-icon {
  font-size: 40rpx;
  line-height: 1;
  color: #1A73E8;
  font-weight: 600;
  margin-right: 6rpx;
}
.back-text {
  font-size: 26rpx;
  color: #1A73E8;
  line-height: 1;
}

.form-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 16rpx;
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-md);
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--text-regular);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input,
.picker-value,
.textarea {
  width: 100%;
  background-color: var(--bg-section);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  transition: border-color 0.2s, background-color 0.2s;
}
.input,
.picker-value { height: 80rpx; line-height: 80rpx; }
.textarea { min-height: 160rpx; padding: 20rpx; line-height: 1.6; resize: vertical; }
.input:focus,
.picker-value:focus,
.textarea:focus { border-color: var(--primary-color); background-color: var(--white); }
.picker-value.placeholder { color: var(--text-placeholder); }

.info-box {
  background-color: var(--bg-section);
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-regular);
  line-height: 1.6;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-stock {
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.06);
  color: var(--success-color);
  font-weight: 600;
  font-size: 30rpx;
}

.btn-primary {
  background-color: var(--primary-color);
  color: var(--text-inverse);
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-top: 24rpx;
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.85; }

.dest-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.dest-picker {
  flex: 1;
  min-width: 0;
}
.dest-picker .picker-value {
  background-color: var(--bg-section);
}
.btn-add-dest {
  flex-shrink: 0;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  background-color: rgba(26, 115, 232, 0.08);
  border: 2rpx solid var(--primary-color);
  border-radius: 12rpx;
  white-space: nowrap;
}
.btn-add-dest::after { border: none; }

/* ====== 各尺码明细表 ====== */
.size-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.size-quick-btns {
  display: flex;
  gap: 12rpx;
}
.size-quick-btn {
  font-size: 24rpx;
  color: var(--primary-color);
  background-color: rgba(26, 115, 232, 0.08);
  border: 2rpx solid rgba(26, 115, 232, 0.3);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  line-height: 1.4;
}
.size-loading {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary, #888);
  padding: 40rpx 0;
}
.size-empty {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary, #888);
  padding: 40rpx 0;
}

.size-table {
  background-color: var(--bg-section);
  border-radius: 12rpx;
  padding: 4rpx 0;
}
.size-thead,
.size-row {
  display: flex;
  align-items: center;
  padding: 12rpx 12rpx;
}
.size-thead {
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.08);
}
.size-row + .size-row {
  border-top: 2rpx solid rgba(0, 0, 0, 0.04);
}

.col-size { flex: 0 0 90rpx; text-align: center; }
.col-stock { flex: 1.2; text-align: center; }
.col-out { flex: 1.4; text-align: center; }

.size-th {
  font-size: 22rpx;
  color: var(--text-secondary, #888);
  font-weight: 500;
}

.size-tag {
  display: inline-block;
  background-color: rgba(26, 115, 232, 0.1);
  color: var(--primary-color, #1A73E8);
  font-size: 26rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  min-width: 56rpx;
}

.size-num {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}
.size-num.zero {
  color: var(--text-placeholder, #c0c4cc);
}

.size-input {
  width: 100%;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color, #1A73E8);
  background-color: var(--white);
  border: 2rpx solid rgba(26, 115, 232, 0.2);
  border-radius: 8rpx;
  box-sizing: border-box;
  padding: 0 8rpx;
}
.size-input-ph {
  color: var(--text-placeholder, #c0c4cc);
  font-weight: 400;
}

.size-total-row {
  background-color: rgba(26, 115, 232, 0.05);
  border-top: 2rpx solid rgba(0, 0, 0, 0.08) !important;
  margin-top: 4rpx;
}
.size-total-label {
  font-size: 24rpx;
  color: var(--text-regular, #555);
  font-weight: 600;
}
.size-total-num {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
}
.size-total-out {
  font-size: 30rpx;
  color: var(--primary-color, #1A73E8);
  font-weight: 700;
}

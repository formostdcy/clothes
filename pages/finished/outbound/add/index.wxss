/* pages/finished/outbound/add/index.wxss */
.form-container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 16rpx;
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-md);
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--text-regular);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input,
.picker-value,
.textarea {
  width: 100%;
  background-color: var(--bg-section);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  transition: border-color 0.2s, background-color 0.2s;
}
.input,
.picker-value { height: 80rpx; line-height: 80rpx; }
.textarea { min-height: 160rpx; padding: 20rpx; line-height: 1.6; resize: vertical; }
.input:focus,
.picker-value:focus,
.textarea:focus { border-color: var(--primary-color); background-color: var(--white); }
.picker-value.placeholder { color: var(--text-placeholder); }

.info-box {
  background-color: var(--bg-section);
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-regular);
  line-height: 1.6;
}

.btn-primary {
  background-color: var(--primary-color);
  color: var(--text-inverse);
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-top: 24rpx;
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.85; }

.dest-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.dest-picker {
  flex: 1;
  min-width: 0;
}
.dest-picker .picker-value {
  background-color: var(--bg-section);
}
.btn-add-dest {
  flex-shrink: 0;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  background-color: rgba(26, 115, 232, 0.08);
  border: 2rpx solid var(--primary-color);
  border-radius: 12rpx;
  white-space: nowrap;
}
.btn-add-dest::after { border: none; }

.info-box {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.info-stock {
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.06);
  color: var(--success-color);
  font-weight: 600;
  font-size: 30rpx;
}

/* pages/finished/confirm/list/index.wxss */

/* ====== 根容器 ======
   修：补全 width: 100% + overflow-x: hidden 兜底 */
.container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: 20rpx 24rpx 32rpx;
  box-sizing: border-box;
  overflow-x: hidden;       /* 关键：禁止横向滚动 */
}

.list {
  width: 100%;
  max-width: 100%;
  background-color: var(--white);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-md);
  box-sizing: border-box;
}

.list-item {
  width: 100%;
  max-width: 100%;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--divider);
  position: relative;
  box-sizing: border-box;   /* 关键 */
  overflow: hidden;         /* 关键 */
}
.list-item:last-child { border-bottom: none; }
.list-item.list-item--todo { border-left: 6rpx solid var(--warning-color); padding-left: 18rpx; }

.item-info {
  margin-bottom: 20rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}
.item-no {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
  line-height: 1.3;
  white-space: nowrap;       /* 修：补全单行省略 */
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}
.item-source, .item-material, .item-count, .item-time {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  line-height: 1.5;
  white-space: nowrap;       /* 修：补全单行省略 */
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}
.item-source {
  color: var(--primary-color);
  font-weight: 500;
}

.item-actions {
  display: flex;
  gap: 16rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  min-height: 72rpx;
  line-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  color: var(--text-inverse);
  line-height: 1;
  padding: 0 4rpx;
  margin: 0;
  box-sizing: border-box;
  overflow: hidden;
  letter-spacing: 0;
  white-space: nowrap;
}
.action-btn::after { border: none; }
.action-btn.confirm { background-color: var(--success-color); }
.action-btn.problem { background-color: var(--danger-color); }

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}
